# Sidebar Code SP2 — environment variables.
# Copy this file to `.env` for local development (never commit `.env`).
# Production values live in Render environment variables.
# Variable names match Section 6 of docs/superpowers/specs/2026-04-13-stripe-delivery-design.md

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2 (S3-compatible object storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Transactional email
POSTMARK_API_TOKEN=
KYLE_ALERT_EMAIL=

# Local storage + site config
SQLITE_PATH=
SITE_BASE_URL=
